---
const jugadores = [
  {
    nombre: "Facundo Cambeses",
    posicion: "Arquero",
    imagen: "https://www.racingclub.com.ar/img/futbol/plantel/1583_cambeses.jpg?v=20260325"
  },
  {
    nombre: "Gabriel Rojas",
    posicion: "Defensor",
    imagen: "https://www.racingclub.com.ar/img/futbol/plantel/1398_rojas.jpg?v=20260325"
  },
  {
    nombre: "Adrian Martinez",
    posicion: "Delantero",
    imagen: "https://www.racingclub.com.ar/img/futbol/plantel/1586_martinez.jpg?v=20260325"
  }
];
---

<h1>Plantel actual</h1>

<input id="buscador" type="text" placeholder="Buscar jugador..." />

<section class="jugadores">
{
  jugadores.map(jugador => (
    <div class="card jugador">
      <img src={jugador.imagen} />
      <h3>{jugador.nombre}</h3>
      <p>{jugador.posicion}</p>
    </div>
  ))
}
</section>

<style>
body{
background:#0b1d3a;
color:white;
font-family:Arial;
text-align:center;
}

input{
padding:10px;
margin:20px auto;
display:block;
max-width:300px;
width:100%;
}

.jugadores{
max-width:900px;
margin:20px auto;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
}

.card{
background:#009ddd;
padding:15px;
border-radius:10px;
color:black;
}

.card img{
width:100%;
border-radius:10px;
}
</style>

<script>
const input = document.getElementById("buscador");
const jugadores = document.querySelectorAll(".jugador");

input.addEventListener("input", () => {
  const valor = input.value.toLowerCase();

  jugadores.forEach(j => {
    const texto = j.innerText.toLowerCase();

    j.style.display = texto.includes(valor) ? "block" : "none";
  });
});
</script>